#!/usr/bin/env bash
# Build the generated Starship config when its inputs are stale.

set -euo pipefail

usage() {
    cat >&2 <<'EOF'
usage: starship/build [--theme NAME] [--out PATH] [--force]

Builds ~/.config/starship.toml from the gruvbox-rainbow preset and local
overlays. Without --force, generation is skipped when the output header
fingerprint matches the selected theme, local inputs, Starship version, and yq
version.
EOF
}

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
THEME="${STARSHIP_THEME:-gruvbox}"
OUT=""
FORCE=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --theme)
            [[ $# -ge 2 ]] || { usage; exit 2; }
            THEME="$2"
            shift 2
            ;;
        --out)
            [[ $# -ge 2 ]] || { usage; exit 2; }
            OUT="$2"
            shift 2
            ;;
        --force)
            FORCE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 2
            ;;
    esac
done

OUT="${OUT:-$HOME/.config/starship.toml}"
LAYOUT="$SCRIPT_DIR/overlays/layout.toml"
PALETTE=""
FINGERPRINT_PREFIX="# dotfiles-starship-fingerprint:"

if [[ "$THEME" != "gruvbox" ]]; then
    candidate="$SCRIPT_DIR/overlays/palette-$THEME.toml"
    if [[ -f "$candidate" ]]; then
        PALETTE="$candidate"
    else
        printf "starship/build: warning: no palette overlay for theme '%s'; using gruvbox colors\n" "$THEME" >&2
    fi
fi

STARSHIP_BIN="$(command -v starship || true)"
YQ_BIN="$(command -v yq || true)"

if [[ -z "$STARSHIP_BIN" ]]; then
    printf 'starship/build: error: starship not found in PATH\n' >&2
    exit 127
fi

if [[ -z "$YQ_BIN" ]]; then
    printf 'starship/build: error: yq not found in PATH\n' >&2
    exit 127
fi

sources=("$SCRIPT_DIR/build" "$LAYOUT")
if [[ -n "$PALETTE" ]]; then
    sources+=("$PALETTE")
fi

for src in "${sources[@]}"; do
    if [[ ! -e "$src" ]]; then
        printf 'starship/build: error: source missing: %s\n' "$src" >&2
        exit 1
    fi
done

fingerprint="$(
    {
        printf 'theme=%s\n' "$THEME"
        printf 'starship=%s\n' "$("$STARSHIP_BIN" --version)"
        printf 'yq=%s\n' "$("$YQ_BIN" --version)"
        printf 'palette=%s\n' "${PALETTE:-none}"
        for src in "${sources[@]}"; do
            printf 'file=%s\n' "$src"
            shasum -a 256 "$src"
        done
    } | shasum -a 256 | awk '{print $1}'
)"
header="$FINGERPRINT_PREFIX $fingerprint"

stale="$FORCE"
if [[ ! -e "$OUT" ]]; then
    stale=1
elif [[ "$stale" -eq 0 ]]; then
    current_header="$(head -n 1 "$OUT")"
    if [[ "$current_header" != "$header" ]]; then
        stale=1
    fi
fi

if [[ "$stale" -eq 0 ]]; then
    exit 0
fi

out_dir="$(dirname "$OUT")"
out_name="$(basename "$OUT")"
mkdir -p "$out_dir"
tmp="$(mktemp "$out_dir/.$out_name.XXXXXX")"
cleanup() {
    rm -f "$tmp"
}
trap cleanup EXIT

inputs=(- "$LAYOUT")
if [[ -n "$PALETTE" ]]; then
    inputs+=("$PALETTE")
fi

{
    printf '%s\n' "$header"
    "$STARSHIP_BIN" preset gruvbox-rainbow \
        | "$YQ_BIN" eval-all -p=toml -o=toml '. as $item ireduce ({}; . * $item)' "${inputs[@]}"
} > "$tmp"

mv "$tmp" "$OUT"
trap - EXIT
