shell-integration = fish

# Follow macOS light/dark appearance. Dark: true black + distinct ANSI colors for agent output.
# Light: warm pale yellow background with the same strong color differentiation.
theme = light:Gruvbox Light Hard,dark:Builtin Tango Dark
window-theme = system

# macOS-only: draw glyphs with a thicker stroke for clearer text.
font-thicken = true
font-feature = -calt
shell-integration-features = ssh-terminfo,ssh-env
